# --- Required ---

# Secret for session JWT signing + OTP HMAC. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Anthropic API key — powers the call evaluation (Claude Opus 4.8)
ANTHROPIC_API_KEY=

# OpenAI API key — powers audio transcription (Whisper)
OPENAI_API_KEY=

# --- Optional: Google SSO (the Google button is hidden if these are unset) ---
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional locally, required in production for Email OTP ---
# https://resend.com — without this, dev mode shows the OTP code on screen
RESEND_API_KEY=
# Must be a verified sender/domain in Resend
EMAIL_FROM="Call Quality Audit <onboarding@resend.dev>"
